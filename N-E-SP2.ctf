O:a) "0", b) "1", c) "2", d) "1/2"
R:"\\(\\sec(\\frac{\\pi}{3}) = \\frac{1}{\\cos(60^\\circ)} = \\frac{1}{1/2} = 2\\)."
}

q {
Q:"\\(f(x) = C\\) is a:"
A:"B"O:a) "Identity function", b) "Constant function", c) "Linear function", d) "Quadratic function"
R:"A function that outputs the same value C for all inputs is a constant function."
}

q {
Q:"\\(\\cosh^2 x + \\sinh^2 x\\) equals:"
A:"C"
O:a) "\\(\\sinh 2x\\)", b) "\\(-\\sinh 2x\\)", c) "\\(\\cosh 2x\\)", d) "\\(-\\cosh 2x\\)"
R:"This is the hyperbolic double angle identity: \\(\\cosh 2x = \\cosh^2 x + \\sinh^2 x\\)."
}

q {
Q:"\\(\\lim_{x \\to 0} \\frac{e^x - 1}{x}\\) equals:"
A:"B"
O:a) "e", b) "1", c) "n a^{n-1}", d) "\\(\\log_e a\\)"
