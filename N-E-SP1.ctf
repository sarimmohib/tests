}

q {
Q:"If A is any matrix then its additive inverse is:"
A:"d"
O:a) "A", b) "\\(A^{-1}\\)", c) "\\(A^t\\)", d) "-A"
R:"\\(A + (-A) = 0\\) (zero matrix), satisfying the additive inverse property."
}

q {
