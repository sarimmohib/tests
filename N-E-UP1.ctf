A:"b"
O:a) "\\(r\\cos\\theta + r\\sin\\theta\\)", b) "\\(r\\cos\\theta + ir\\sin\\theta\\)", c) "\\(r\\sin\\theta + r\\cos\\theta\\)", d) "\\(ir\\cos\\theta + r\\sin\\theta\\)"
R:"The standard polar form is \\(r(\\cos\\theta + i\\sin\\theta)\\)."
}

q {
